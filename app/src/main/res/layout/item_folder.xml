<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/folderRoot"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_list_item"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="4dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- أيقونة المجلد -->
    <ImageView
        android:id="@+id/ivFolderIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_folder"
        android:tint="@color/accent_blue"
        android:padding="4dp"/>

    <!-- النصوص: الاسم + العدد -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <!-- اسم المجلد - RTL آمن مع ellipsize -->
        <TextView
            android:id="@+id/tvFolderName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/lib_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:textDirection="locale"/>

        <!-- عدد الفيديوهات -->
        <TextView
            android:id="@+id/tvFolderCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/lib_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="3dp"
            android:textDirection="locale"/>

    </LinearLayout>

    <!-- سهم التنقل -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_arrow_back"
        android:tint="@color/lib_text_secondary"
        android:rotation="180"/>

</LinearLayout>
