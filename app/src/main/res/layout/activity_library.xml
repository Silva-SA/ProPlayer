<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/libDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- المحتوى الرئيسي -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/lib_bg">

        <!-- شريط العنوان -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:background="@color/lib_toolbar"
            android:elevation="4dp">

            <!-- زر الرجوع (يظهر عند فتح مجلد) -->
            <ImageButton
                android:id="@+id/btnBackLib"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/btn_icon_ripple"
                android:tint="@color/lib_text_primary"
                android:padding="12dp"
                android:visibility="gone"
                android:contentDescription="رجوع"/>

            <TextView
                android:id="@+id/tvScreenTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LREC Player"
                android:textColor="@color/lib_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="12dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/tvVideoCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/lib_text_secondary"
                android:textSize="12sp"
                android:paddingEnd="8dp"/>

            <!-- زر تحديث -->
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_refresh"
                android:background="@drawable/btn_icon_ripple"
                android:tint="@color/lib_text_primary"
                android:padding="10dp"
                android:contentDescription="تحديث"/>

            <!-- زر القائمة -->
            <ImageButton
                android:id="@+id/btnMenuTop"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_menu"
                android:background="@drawable/btn_icon_ripple"
                android:tint="@color/lib_text_primary"
                android:padding="10dp"
                android:contentDescription="القائمة"/>

        </LinearLayout>

        <!-- مؤشر التحميل -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="80dp"
            android:visibility="gone"/>

        <!-- رسالة فارغة -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="48dp"
            android:textSize="15sp"
            android:textColor="@color/lib_text_secondary"
            android:visibility="gone"/>

        <!-- القائمة -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- القائمة الجانبية للمكتبة -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/libNavigationView"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/drawer_bg"
        app:menu="@menu/library_menu"
        app:itemTextColor="@color/drawer_text"
        app:itemIconTint="@color/accent_blue"/>

</androidx.drawerlayout.widget.DrawerLayout>
