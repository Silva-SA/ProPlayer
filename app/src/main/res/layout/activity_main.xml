<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- مشغل الفيديو -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:use_artwork="false"
            android:background="#000000"/>

        <!-- شاشة الترحيب عند عدم وجود فيديو -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:background="#000000">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@mipmap/ic_launcher"
                android:alpha="0.7"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LREC Player"
                android:textColor="#FFFFFFFF"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اضغط الزر أدناه لاختيار فيديو"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <!-- زر اختيار فيديو كبير -->
            <LinearLayout
                android:id="@+id/btnOpenFileBig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_open_btn"
                android:padding="14dp"
                android:layout_marginTop="32dp"
                android:clickable="false">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_folder"
                    android:tint="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  اختر فيديو"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Overlay تعتيم -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_overlay"
            android:alpha="0"/>

        <!-- Overlay مستوى الصوت -->
        <LinearLayout
            android:id="@+id/volumeOverlay"
            android:layout_width="52dp"
            android:layout_height="190dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_pill"
            android:visibility="invisible"
            android:padding="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_volume"
                android:tint="#FFFFFF"/>

            <FrameLayout
                android:layout_width="6dp"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track"/>

                <View
                    android:id="@+id/volumeBar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_progress_fill"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tvVolumePercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>

        </LinearLayout>

        <!-- Overlay مستوى السطوع -->
        <LinearLayout
            android:id="@+id/brightnessOverlay"
            android:layout_width="52dp"
            android:layout_height="190dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="20dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_pill"
            android:visibility="invisible"
            android:padding="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_brightness"
                android:tint="#FFFFFF"/>

            <FrameLayout
                android:layout_width="6dp"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track"/>

                <View
                    android:id="@+id/brightnessBar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_progress_fill_brightness"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tvBrightnessPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>

        </LinearLayout>

        <!-- شريط أعلى الشاشة -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:background="@drawable/gradient_top"
            android:visibility="invisible"
            android:alpha="0">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_menu"
                android:background="@drawable/btn_icon_ripple"
                android:tint="#FFFFFF"
                android:padding="12dp"
                android:contentDescription="Menu"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LREC Player"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="6dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <!-- زر فتح ملف في شريط العنوان -->
            <ImageButton
                android:id="@+id/btnOpenFile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_folder"
                android:background="@drawable/btn_icon_ripple"
                android:tint="#FFFFFF"
                android:padding="12dp"
                android:contentDescription="Open Video"/>

        </LinearLayout>

        <!-- لوحة تحكم سفلية -->
        <LinearLayout
            android:id="@+id/playerControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@drawable/gradient_bottom"
            android:paddingBottom="20dp"
            android:paddingTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="invisible"
            android:alpha="0">

            <!-- شريط التقدم -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="32dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_seekbar_track"/>

                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_seekbar_fill"/>

                <View
                    android:id="@+id/progressThumb"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_seekbar_thumb"/>

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="@null"
                    android:progressDrawable="@android:color/transparent"
                    android:thumb="@android:color/transparent"
                    android:max="1000"/>

            </FrameLayout>

            <!-- عرض الوقت -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- أزرار التحكم -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="8dp">

                    <ImageButton
                        android:id="@+id/btnRewind"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_rewind"
                        android:background="@drawable/btn_control_ripple"
                        android:tint="#FFFFFF"
                        android:padding="16dp"
                        android:contentDescription="Rewind"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:text="10"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"/>

                </FrameLayout>

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">

                    <View
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_play_button"/>

                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_play"
                        android:background="@drawable/btn_play_ripple"
                        android:tint="#FFFFFF"
                        android:padding="18dp"
                        android:contentDescription="Play Pause"/>

                </FrameLayout>

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="8dp">

                    <ImageButton
                        android:id="@+id/btnForward"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_forward"
                        android:background="@drawable/btn_control_ripple"
                        android:tint="#FFFFFF"
                        android:padding="16dp"
                        android:contentDescription="Forward"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:text="10"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"/>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
