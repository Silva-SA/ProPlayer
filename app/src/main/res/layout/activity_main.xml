<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- مشغل الفيديو -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:use_artwork="false"
            android:background="#000000"/>

        <!-- Overlay مستوى الصوت (يمين) -->
        <LinearLayout
            android:id="@+id/volumeOverlay"
            android:layout_width="52dp"
            android:layout_height="190dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_pill"
            android:visibility="invisible"
            android:padding="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_volume"
                android:tint="#FFFFFF"/>

            <FrameLayout
                android:layout_width="6dp"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track"/>
                <View
                    android:id="@+id/volumeBar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_progress_fill"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvVolumePercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Overlay مستوى السطوع (يسار) -->
        <LinearLayout
            android:id="@+id/brightnessOverlay"
            android:layout_width="52dp"
            android:layout_height="190dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="20dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_pill"
            android:visibility="invisible"
            android:padding="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_brightness"
                android:tint="#FFFFFF"/>

            <FrameLayout
                android:layout_width="6dp"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track"/>
                <View
                    android:id="@+id/brightnessBar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_progress_fill_brightness"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvBrightnessPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- شريط العنوان العلوي -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:background="@drawable/gradient_top"
            android:visibility="visible"
            android:alpha="1">

            <!-- زر الرجوع للمكتبة -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/btn_icon_ripple"
                android:tint="#FFFFFF"
                android:padding="12dp"
                android:contentDescription="رجوع"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LREC Player"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <!-- زر تدوير سريع -->
            <ImageButton
                android:id="@+id/btnRotate"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_rotate"
                android:background="@drawable/btn_icon_ripple"
                android:tint="#FFFFFF"
                android:padding="10dp"
                android:contentDescription="تدوير"/>

            <!-- زر القائمة -->
            <ImageButton
                android:id="@+id/btnPlayerMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_menu"
                android:background="@drawable/btn_icon_ripple"
                android:tint="#FFFFFF"
                android:padding="12dp"
                android:contentDescription="القائمة"

        </LinearLayout>

        <!-- لوحة التحكم السفلية -->
        <LinearLayout
            android:id="@+id/playerControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@drawable/gradient_bottom"
            android:paddingBottom="20dp"
            android:paddingTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="visible"
            android:alpha="1">

            <!-- شريط التقدم -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="32dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_seekbar_track"/>
                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_seekbar_fill"/>
                <View
                    android:id="@+id/progressThumb"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_seekbar_thumb"/>
                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="@null"
                    android:progressDrawable="@android:color/transparent"
                    android:thumb="@android:color/transparent"
                    android:max="1000"/>
            </FrameLayout>

            <!-- الوقت -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">
                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- أزرار التحكم -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="8dp">
                    <ImageButton
                        android:id="@+id/btnRewind"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_rewind"
                        android:background="@drawable/btn_control_ripple"
                        android:tint="#FFFFFF"
                        android:padding="16dp"
                        android:contentDescription="10 ثوان للخلف"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:text="10"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"/>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">
                    <View
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_play_button"/>
                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_play"
                        android:background="@drawable/btn_play_ripple"
                        android:tint="#FFFFFF"
                        android:padding="18dp"
                        android:contentDescription="تشغيل إيقاف"/>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="8dp">
                    <ImageButton
                        android:id="@+id/btnForward"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_forward"
                        android:background="@drawable/btn_control_ripple"
                        android:tint="#FFFFFF"
                        android:padding="16dp"
                        android:contentDescription="10 ثوان للأمام"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:text="10"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"/>
                </FrameLayout>

            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

    <!-- القائمة الجانبية -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/drawer_bg"
        app:menu="@menu/player_menu"
        app:itemTextColor="@color/drawer_text"
        app:itemIconTint="@color/accent_blue"/>

</androidx.drawerlayout.widget.DrawerLayout>
