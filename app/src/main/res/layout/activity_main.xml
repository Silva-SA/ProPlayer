<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- مشغل الفيديو -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:use_artwork="false"
            android:background="#000000" />

        <!-- Overlay تعتيم خلفية التحكم -->
        <View
            android:id="@+id/controlsBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_overlay"
            android:alpha="0"
            android:visibility="visible"/>

        <!-- Overlay مستوى الصوت -->
        <LinearLayout
            android:id="@+id/volumeOverlay"
            android:layout_width="56dp"
            android:layout_height="200dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_pill"
            android:visibility="invisible"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivVolumeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_volume"
                android:tint="#FFFFFF"/>

            <!-- شريط الصوت العمودي -->
            <FrameLayout
                android:layout_width="6dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <!-- خلفية الشريط -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track"/>

                <!-- مؤشر مستوى الصوت -->
                <View
                    android:id="@+id/volumeBar"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_progress_fill"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tvVolumePercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- Overlay مستوى السطوع -->
        <LinearLayout
            android:id="@+id/brightnessOverlay"
            android:layout_width="56dp"
            android:layout_height="200dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="24dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_overlay_pill"
            android:visibility="invisible"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_brightness"
                android:tint="#FFFFFF"/>

            <FrameLayout
                android:layout_width="6dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_track"/>

                <View
                    android:id="@+id/brightnessBar"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_progress_fill_brightness"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tvBrightnessPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- شريط العنوان العلوي -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:background="@drawable/gradient_top"
            android:alpha="0"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_menu"
                android:background="@drawable/btn_icon_ripple"
                android:tint="#FFFFFF"
                android:padding="12dp"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LREC Player"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"/>

        </LinearLayout>

        <!-- لوحة تحكم المشغل السفلية - بتصميم سامسونج -->
        <LinearLayout
            android:id="@+id/playerControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@drawable/gradient_bottom"
            android:paddingBottom="16dp"
            android:paddingTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:alpha="0"
            android:visibility="visible">

            <!-- شريط التقدم -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center_vertical">

                <!-- خلفية الشريط -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_seekbar_track"/>

                <!-- تقدم التشغيل -->
                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_seekbar_fill"/>

                <!-- نقطة المؤشر -->
                <View
                    android:id="@+id/progressThumb"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_seekbar_thumb"/>

                <!-- شريط لمسي شفاف -->
                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="@null"
                    android:progressDrawable="@android:color/transparent"
                    android:thumb="@android:color/transparent"
                    android:max="1000"/>

            </FrameLayout>

            <!-- الوقت -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"/>

            </LinearLayout>

            <!-- أزرار التحكم الرئيسية -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">

                <!-- زر الرجوع 10 ثوان -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="8dp">

                    <ImageButton
                        android:id="@+id/btnRewind"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_rewind"
                        android:background="@drawable/btn_control_ripple"
                        android:tint="#FFFFFF"
                        android:padding="16dp"
                        android:contentDescription="Rewind 10 seconds"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:text="10"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"/>

                </FrameLayout>

                <!-- زر تشغيل/إيقاف - أكبر وأبرز -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">

                    <!-- دائرة خلفية -->
                    <View
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_play_button"/>

                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_play"
                        android:background="@drawable/btn_play_ripple"
                        android:tint="#FFFFFF"
                        android:padding="18dp"
                        android:contentDescription="Play Pause"/>

                </FrameLayout>

                <!-- زر التقديم 10 ثوان -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="8dp">

                    <ImageButton
                        android:id="@+id/btnForward"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_forward"
                        android:background="@drawable/btn_control_ripple"
                        android:tint="#FFFFFF"
                        android:padding="16dp"
                        android:contentDescription="Forward 10 seconds"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:text="10"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"/>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
